# ======================================
# Quiz Platform - Production Environment
# ======================================
# 복사: cp .env.prod.sample .env.prod
# 편집 후 실행: docker compose --env-file .env.prod -f docker/docker-compose.prod.yml up -d

# ---- Image tag ----
IMAGE_TAG=latest

# ---- Public host (SSL 도메인) ----
PUBLIC_HOST=example.com

# ---- Database ----
POSTGRES_DB=quizdb
POSTGRES_USER=quiz
POSTGRES_PASSWORD=__change_me_secure_random__

# ---- RabbitMQ ----
RABBITMQ_DEFAULT_USER=quiz
RABBITMQ_DEFAULT_PASS=__change_me_secure_random__

# ---- JWT ----
# 32바이트 이상. 생성: openssl rand -base64 48
QUIZ_JWT_SECRET=__change_me_min_32_bytes__

# ---- OAuth2 GitHub ----
# GitHub OAuth App: https://github.com/settings/developers
# Callback URL: https://${PUBLIC_HOST}/login/oauth2/code/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- WebSocket CORS ----
# 콤마 구분. 예: https://example.com,https://www.example.com
QUIZ_WEBSOCKET_ALLOWED_ORIGINS=https://example.com

# ---- OAuth redirect (https 필수) ----
QUIZ_AUTH_POST_LOGIN_REDIRECT=https://example.com/auth/callback

# ---- Grafana admin ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=__change_me__

# ---- Tracing ----
# Prod 권장: 0.05 ~ 0.1 (high-volume일수록 낮게)
TRACING_SAMPLING=0.1
